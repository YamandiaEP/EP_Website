---
import Layout from './Layout.astro';
const { szczyt, slug } = Astro.props;
const { nazwa, region, wysokosc, czas, przewyzszenie, trudnosc,
        done, data, photo, photos, instagram, tiktok, gpx, parking } = szczyt;

const trudnoscLabel: Record<string, string> = { 'łatwa': 'Łatwa', 'średnia': 'Średnia', 'trudna': 'Trudna' };
const base = import.meta.env.BASE_URL;
---
<Layout title={`${nazwa} — Yamandia EP`}>
<style>
.szczyt-hero {
  min-height: 55vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 8rem 2rem 3rem;
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid var(--border);
}
.szczyt-photo {
  position: absolute;
  inset: 0;
  object-fit: cover;
  width: 100%;
  height: 100%;
  filter: brightness(0.35);
}
.szczyt-photo-placeholder {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #111, #1a1a1a);
}
.szczyt-hero-content { position: relative; z-index: 1; max-width: 900px; margin: 0 auto; width: 100%; }
.back-link {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
  transition: color 0.2s;
}
.back-link:hover { color: var(--white); }
.szczyt-region {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.6rem;
  display: flex;
  align-items: center;
  gap: 0.7rem;
}
.szczyt-region::before { content: ''; width: 2rem; height: 1px; background: var(--muted); display: block; }
.szczyt-nazwa {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(3.5rem, 9vw, 7rem);
  text-transform: uppercase;
  letter-spacing: -0.03em;
  line-height: 0.88;
  margin-bottom: 1rem;
}
.szczyt-data {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  color: var(--muted);
  letter-spacing: 0.1em;
}
.szczyt-body {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 2rem;
}
.data-bar {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border: 1px solid var(--border);
  border-top: none;
  margin-bottom: 3rem;
}
.db-cell {
  padding: 1.2rem 1.5rem;
  border-right: 1px solid var(--border);
}
.db-cell:last-child { border-right: none; }
.db-key {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.3rem;
}
.db-val {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1.5rem;
  color: var(--white);
  line-height: 1;
}
.actions {
  display: flex;
  gap: 0.6rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid var(--border);
}
.btn-social {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.9rem 1.6rem;
  background: var(--white);
  color: var(--black);
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.2s;
}
.btn-social:hover { background: #ddd; }
.btn-outline {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.9rem 1.6rem;
  background: transparent;
  color: var(--white);
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  border: 1px solid var(--border);
  transition: all 0.2s;
}
.btn-outline:hover { border-color: var(--white); }
.relacja {
  color: var(--muted);
  font-size: 1.05rem;
  line-height: 1.85;
  font-weight: 300;
  max-width: 65ch;
  margin-bottom: 3rem;
}
.relacja :global(p) { margin-bottom: 1.4rem; }
.relacja :global(h2) {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1.5rem;
  text-transform: uppercase;
  color: var(--white);
  margin: 2rem 0 0.8rem;
  letter-spacing: 0.02em;
}
.relacja :global(strong) { color: var(--white); font-weight: 500; }
.gallery {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.5rem;
  margin-bottom: 4rem;
}
.gallery img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  display: block;
}

/* MAPA */
.mapa-section {
  margin-bottom: 3rem;
}
.mapa-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.8rem;
  display: flex;
  align-items: center;
  gap: 0.7rem;
}
.mapa-label::before { content: ''; width: 2rem; height: 1px; background: var(--muted); display: block; }
#mapa {
  width: 100%;
  height: 420px;
  border: 1px solid var(--border);
  background: var(--grey);
}

/* Leaflet dark overrides */
.leaflet-container { background: #080808 !important; }
.leaflet-control-attribution { background: rgba(8,8,8,0.85) !important; color: var(--muted) !important; font-size: 0.55rem !important; }
.leaflet-control-attribution a { color: var(--muted) !important; }
.leaflet-control-zoom a {
  background: var(--grey) !important;
  color: var(--white) !important;
  border-color: var(--border) !important;
}

@media (max-width: 700px) {
  .data-bar { grid-template-columns: repeat(2, 1fr); }
  .db-cell:nth-child(2) { border-right: none; }
  .db-cell:nth-child(3) { border-right: 1px solid var(--border); }
  .gallery { grid-template-columns: repeat(2, 1fr); }
  #mapa { height: 300px; }
}
</style>


<div class="szczyt-hero">
  {photo
    ? <img src={photo} alt={nazwa} class="szczyt-photo" />
    : <div class="szczyt-photo-placeholder"></div>
  }
  <div class="szczyt-hero-content">
    <a href={base} class="back-link">← Wszystkie szczyty</a>
    <div class="szczyt-region">{region}</div>
    <h1 class="szczyt-nazwa">{nazwa}</h1>
    {data && <div class="szczyt-data">Zdobyty: {data}</div>}
  </div>
</div>

<div class="szczyt-body">

  <!-- Kafelki z danymi -->
  <div class="data-bar">
    <div class="db-cell"><div class="db-key">Wysokość</div><div class="db-val">{wysokosc} m</div></div>
    <div class="db-cell"><div class="db-key">Czas przejścia</div><div class="db-val">{czas}</div></div>
    <div class="db-cell"><div class="db-key">Przewyższenie</div><div class="db-val">{przewyzszenie}</div></div>
    <div class="db-cell"><div class="db-key">Trudność</div><div class="db-val">{trudnoscLabel[trudnosc]}</div></div>
  </div>

  <!-- Przyciski akcji -->
  <div class="actions">
    {instagram && (
      <a href={instagram} target="_blank" rel="noopener" class="btn-social">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        Instagram
      </a>
    )}
    {tiktok && (
      <a href={tiktok} target="_blank" rel="noopener" class="btn-social">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/></svg>
        TikTok
      </a>
    )}
    {gpx && <a href={gpx} download class="btn-outline">↓ Pobierz GPX</a>}
    {parking && <a href={parking} target="_blank" rel="noopener" class="btn-outline">⊕ Parking → Maps</a>}
  </div>

  <!-- Mapa GPX -->
  {gpx && (
    <div class="mapa-section">
      <div class="mapa-label">Mapa trasy</div>
      <div id="mapa"></div>
    </div>
  )}

  <!-- Treść relacji z Markdown -->
  <div class="relacja">
    <slot />
  </div>

  <!-- Galeria zdjęć -->
  {photos && photos.length > 0 && (
    <div class="gallery">
      {photos.map((src: string) => (
        <img src={src} alt={`${nazwa} - zdjęcie`} loading="lazy" />
      ))}
    </div>
  )}

</div>

<!-- Leaflet JS + GPX — tylko gdy jest plik GPX -->
{gpx && (
  <Fragment>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script define:vars={{ gpx }}>
      window.addEventListener('load', function() {
        const map = L.map('mapa');

        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
          attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> © <a href="https://carto.com/">CARTO</a>',
          maxZoom: 19,
        }).addTo(map);

        fetch(window.location.origin + gpx)
          .then(r => r.text())
          .then(gpxText => {
            const parser = new DOMParser();
            const xml = parser.parseFromString(gpxText, 'application/xml');
            const points = xml.querySelectorAll('trkpt');
            const latlngs = Array.from(points).map(p => [
              parseFloat(p.getAttribute('lat')),
              parseFloat(p.getAttribute('lon'))
            ]);
            if (latlngs.length > 0) {
              const line = L.polyline(latlngs, {
                color: '#f2f0eb',
                weight: 4,
                opacity: 1,
              }).addTo(map);
              map.fitBounds(line.getBounds(), { padding: [40, 40] });
            }
          })
          .catch(err => console.error('GPX error:', err));
      });
    </script>
  </Fragment>
)}

</Layout>